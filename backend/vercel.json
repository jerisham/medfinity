{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "250mb",
        "runtime": "python3.12",
        "requirements": "api/requirements.txt"
      }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/admin/(.*)", "dest": "api/index.py" },
    { "src": "/", "dest": "/frontend/pages/login.html" },
    { "src": "/pages/(.*)", "dest": "/frontend/pages/$1" },
    { "src": "/css/(.*)", "dest": "/frontend/css/$1" },
    { "src": "/js/(.*)", "dest": "/frontend/js/$1" }
  ]
}
