{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12",
        "requirements": "backend/requirements.txt"
      }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "backend/api/index.py"
    },
    {
      "src": "^/admin/(.*)",
      "dest": "backend/api/index.py"
    },
    {
      "src": "^/$",
      "dest": "/frontend/pages/login.html"
    },
    {
      "src": "^/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
