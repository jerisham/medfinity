{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12",
        "requirements": "backend/requirements.txt"
      }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
 "routes": [
  {
    "src": "^/api/(.*)",
    "dest": "api/index.py"
  },
  {
    "src": "^/admin/(.*)",
    "dest": "api/index.py"
  },

  {
    "src": "^/css/(.*)",
    "dest": "/frontend/css/$1"
  },

  {
    "src": "^/js/(.*)",
    "dest": "/frontend/js/$1"
  },

  {
    "src": "^/$",
    "dest": "/frontend/pages/login.html"
  },

  {
    "src": "^/(.*\\.html)",
    "dest": "/frontend/pages/$1"
  }
]
}
